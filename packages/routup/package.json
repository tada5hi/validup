{
    "name": "@validup/routup",
    "version": "0.2.3",
    "type": "module",
    "description": "A validup integration for routup.",
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/validup.git"
    },
    "main": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build:types": "tsc --noEmit",
        "build:js": "tsdown",
        "build": "npm run build:types && npm run build:js",
        "test": "vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage"
    },
    "keywords": [],
    "license": "MIT",
    "devDependencies": {
        "@routup/basic": "^1.4.3",
        "@types/supertest": "^6.0.2",
        "routup": "^4.1.0",
        "supertest": "^7.2.2",
        "validup": "^0.2.3"
    },
    "peerDependencies": {
        "@routup/basic": "^1.4.3",
        "routup": "^4.1.0",
        "validup": "^0.2.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
